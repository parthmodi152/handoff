# Handoff Server Configuration
# Copy this file to .env and adjust values as needed.

# --- Required for local development ---
HANDOFF_JWT_SECRET=change-me-in-production-at-least-32-bytes!!
HANDOFF_DEV_MODE=true

# --- Server (all have defaults) ---
HANDOFF_PORT=8080
HANDOFF_DB_PATH=handoff.db
HANDOFF_BASE_URL=http://localhost:8080

# --- Apple OAuth (required for production Sign in with Apple) ---
# HANDOFF_APPLE_CLIENT_ID=com.yourapp.auth
# HANDOFF_APPLE_CLIENT_SECRET=your-generated-jwt
# HANDOFF_APPLE_TEAM_ID=ABCDE12345
# HANDOFF_APPLE_KEY_ID=FGHIJ67890

# --- Google OAuth (optional, for Google sign-in) ---
# HANDOFF_GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
# HANDOFF_GOOGLE_CLIENT_SECRET=your-client-secret
